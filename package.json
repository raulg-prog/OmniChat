{
  "name": "stream-chat-aggregator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --filter=!@sca/server build && pnpm --filter @sca/server dev",
    "start": "pnpm -r --filter=!@sca/server build && pnpm --filter @sca/server start",
    "serve": "pnpm build && pnpm --filter @sca/server serve",
    "package:win": "powershell -ExecutionPolicy Bypass -File scripts/package-win.ps1",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.0"
}
